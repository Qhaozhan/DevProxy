{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevProxy",
  "version": "1.0.0",
  "identifier": "com.devproxy.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DevProxy",
        "width": 1180,
        "height": 940,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": [
      "../resources/config/**/*",
      "../resources/certs/**/*"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "nsis": {
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false
      }
    }
  }
}
